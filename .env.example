# Copy to .env for local runs. On Railway, set these as service Variables.

# --- required ---
TELEGRAM_BOT_TOKEN=        # from @BotFather
TELEGRAM_CHAT_ID=          # your numeric chat id (DM @userinfobot to get it)
ANTHROPIC_API_KEY=         # for the weekly reflection

# --- optional ---
ANTHROPIC_MODEL=claude-opus-4-8
DAILY_DELIVERY_TIME=08:00  # Asia/Jerusalem
WEEKLY_REFLECTION_TIME=11:00  # fires Friday, Asia/Jerusalem
DB_PATH=/data/know_thyself.db   # set to ./know_thyself.db for local runs

# --- question store (optional; omit to use app/seed_questions.json) ---
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=    # full service-account JSON, single line
